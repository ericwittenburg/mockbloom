# MockBloom backend configuration. Copy this file to `.env` and fill in real values.

# --- Server ---
# Port the Express server listens on. Render sets PORT automatically; locally we use 3001.
PORT=3001

# Comma-separated list of origins allowed to call this API.
# Include your local frontend (e.g. http://localhost:3000) and your deployed frontend URL.
FRONTEND_URL=http://localhost:3000

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
# The URL of your Supabase project (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=

# Public anon key — safe to ship to clients, used to scope requests to a user via their JWT.
SUPABASE_ANON_KEY=

# Service role key — bypasses RLS. NEVER expose to the browser.
# Used here only for server-to-Supabase-Storage uploads.
SUPABASE_SERVICE_ROLE_KEY=

# --- Storage ---
# Names of the two private buckets you create in Supabase Storage.
# Both must exist before the server can store files.
TEMPLATES_BUCKET=templates
MOCKUPS_BUCKET=mockups

# --- Uploads ---
# Maximum per-file size in bytes. Default 8 MB — shirt PNGs are usually under this.
MAX_UPLOAD_BYTES=8388608
